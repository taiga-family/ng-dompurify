{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "ng-dompurify",
    "projectType": "library",
    "sourceRoot": "libs/ng-event-plugins/src",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:ng-packagr",
            "options": {
                "project": "projects/{projectName}/ng-package.json",
                "tsConfig": "projects/{projectName}/tsconfig.lib.json"
            }
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["cp ./LICENSE ./README.md ./dist/{projectName}", "npm publish ./dist/{projectName} --ignore-scripts"],
                "parallel": false
            }
        }
    }
}
