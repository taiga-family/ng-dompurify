{
    "name": "ng-dompurify",
    "version": "5.0.1",
    "private": true,
    "description": "Inclusive Angular API for DOMPurify",
    "keywords": [
        "angular",
        "ng",
        "dompurify",
        "DomSanitizer"
    ],
    "homepage": "https://github.com/taiga-family/ng-dompurify#README",
    "repository": {
        "type": "git",
        "url": "https://github.com/taiga-family/ng-dompurify"
    },
    "license": "Apache-2.0",
    "author": {
        "email": "79601794011@ya.ru",
        "name": "Roman Sedov",
        "url": "http://marsibarsi.me/"
    },
    "contributors": [
        {
            "email": "alexander@inkin.ru",
            "name": "Alex Inkin"
        }
    ],
    "workspaces": [
        "projects/*"
    ],
    "scripts": {
        "build:demo": "nx build demo -c production",
        "build:library": "nx build ng-dompurify",
        "build:ssr": "nx run demo:build:production && nx run demo:server:production",
        "postinstall": "husky install",
        "lint": "eslint .",
        "postbuild": "node scripts/postbuild.js",
        "prettier": "prettier !package-lock.json !CHANGELOG.md . --ignore-path .gitignore",
        "release": "npx syncer && npx nx run-many --target publish --all",
        "start": "nx serve demo",
        "start:ssr": "nx serve-ssr demo",
        "stylelint": "stylelint '**/*.{less,css}'",
        "test": "jest",
        "typecheck": "tsc --noEmit --skipLibCheck"
    },
    "commitlint": {
        "extends": [
            "@taiga-ui/commitlint-config"
        ]
    },
    "lint-staged": {
        "*.less": [
            "stylelint --fix"
        ],
        "*.{js,ts,html}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{svg,yml,md,less,json}": [
            "prettier --write"
        ]
    },
    "browserslist": [
        "extends @taiga-ui/browserslist-config"
    ],
    "prettier": "@taiga-ui/prettier-config",
    "stylelint": {
        "extends": [
            "@taiga-ui/stylelint-config"
        ],
        "ignoreFiles": [
            "**/demo/**",
            "**/dist/**",
            "**/coverage/**",
            "**/node_modules/**"
        ]
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "19.2.24",
        "@angular-devkit/core": "19.2.24",
        "@angular-devkit/schematics": "19.2.24",
        "@angular/animations": "19.2.21",
        "@angular/cli": "19.2.24",
        "@angular/common": "19.2.21",
        "@angular/compiler": "19.2.21",
        "@angular/compiler-cli": "19.2.21",
        "@angular/core": "19.2.21",
        "@angular/forms": "19.2.21",
        "@angular/language-service": "19.2.21",
        "@angular/platform-browser": "19.2.21",
        "@angular/platform-browser-dynamic": "19.2.21",
        "@angular/platform-server": "19.2.21",
        "@angular/router": "19.2.21",
        "@angular/ssr": "19.2.24",
        "@ng-web-apis/common": "5.2.0",
        "@ng-web-apis/universal": "5.2.0",
        "@nx/angular": "21.6.11",
        "@nx/eslint": "21.6.11",
        "@nx/jest": "21.6.11",
        "@nx/linter": "19.8.4",
        "@nx/node": "21.6.11",
        "@nx/workspace": "21.6.11",
        "@schematics/angular": "19.2.24",
        "@taiga-ui/configs": "0.497.0",
        "@types/express": "5.0.6",
        "@types/jest": "29.5.14",
        "@types/node": "22.19.17",
        "browser-sync": "3.0.4",
        "core-js": "3.49.0",
        "express": "4.22.1",
        "glob": "11.1.0",
        "husky": "9.1.7",
        "jest": "29.7.0",
        "jest-preset-angular": "14.6.2",
        "ng-packagr": "19.2.2",
        "nx": "21.6.11",
        "rxjs": "7.8.2",
        "ts-jest": "29.4.9",
        "ts-node": "10.9.2",
        "typescript": "5.7.3"
    },
    "syncer": {
        "includePaths": [
            "./projects",
            "./package-lock.json"
        ],
        "matchPackageNames": [
            "@taiga-ui/dompurify",
            "ng-dompurify"
        ]
    }
}
